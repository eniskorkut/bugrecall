{
  "name": "project-memory-agent",
  "version": "0.2.0",
  "private": true,
  "description": "Bugrecall: local-first debug memory MCP server for AI coding agents",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "keywords": [
    "mcp",
    "ai-agents",
    "coding-agents",
    "debug-memory",
    "local-first",
    "rag",
    "developer-tools"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/eniskorkut/bugrecall.git"
  },
  "bugs": {
    "url": "https://github.com/eniskorkut/bugrecall/issues"
  },
  "homepage": "https://github.com/eniskorkut/bugrecall#readme",
  "bin": {
    "pma": "./bin/pma.js"
  },
  "files": [
    "bin",
    "dist",
    "src/dashboard/static",
    "examples",
    "docs",
    "README.md",
    "LICENSE",
    "CHANGELOG.md",
    "SECURITY.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/index.ts",
    "dashboard:dev": "tsx src/cli.ts dashboard",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "phase2:check": "tsx src/scripts/phase2-check.ts",
    "phase3:check": "tsx src/scripts/phase3-check.ts",
    "phase3:quality": "tsx src/scripts/phase3-quality-check.ts",
    "phase4:check": "tsx src/scripts/phase4-check.ts",
    "phase5a:check": "tsx src/scripts/phase5a-check.ts",
    "phase5b:check": "tsx src/scripts/phase5b-check.ts",
    "phase6:check": "tsx src/scripts/phase6-check.ts",
    "phase7:check": "tsx src/scripts/phase7-check.ts",
    "phase8:check": "tsx src/scripts/phase8-check.ts",
    "phase9a:check": "tsx src/scripts/phase9a-check.ts",
    "phase9b:check": "tsx src/scripts/phase9b-check.ts",
    "phase10:check": "tsx src/scripts/phase10-check.ts",
    "phase11a:check": "npm run build && node dist/scripts/phase11a-check.js",
    "phase11b:check": "npm run build && node dist/scripts/phase11b-check.js",
    "phase11c:check": "npm run build && node dist/scripts/phase11c-check.js",
    "phase11d:check": "npm run build && node dist/scripts/phase11d-check.js",
    "phase12a:check": "node dist/scripts/phase12a-check.js",
    "phase12b:check": "node dist/scripts/phase12b-check.js",
    "phase12c:check": "node dist/scripts/phase12c-check.js",
    "phase12d:check": "node dist/scripts/phase12d-check.js",
    "phase12e:check": "node dist/scripts/phase12e-check.js",
    "eval:retrieval": "node dist/scripts/eval-retrieval.js",
    "doctor": "node dist/scripts/doctor.js",
    "phase13a:check": "node dist/scripts/phase13a-check.js",
    "phase13b:check": "node dist/scripts/phase13b-check.js",
    "phase13c:check": "node dist/scripts/phase13c-check.js",
    "package:check": "node dist/scripts/package-check.js",
    "phase13d:check": "node dist/scripts/phase13d-check.js",
    "final:check": "node dist/scripts/final-readiness-check.js",
    "phase14a:check": "node dist/scripts/phase14a-check.js",
    "phase14b:check": "node dist/scripts/phase14b-check.js",
    "phase14c:check": "node dist/scripts/phase14c-check.js",
    "phase14d:check": "node dist/scripts/phase14d-check.js",
    "phase14e:check": "node dist/scripts/phase14e-check.js",
    "phase14f:check": "tsx src/scripts/phase14f-target-override-check.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "@huggingface/transformers": "^3.7.6",
    "better-sqlite3": "^11.8.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.15.17",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3"
  }
}
